generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum AppointmentStatus {
  scheduled
  rescheduled
  paid_pending
  pending_payment
  completed
  cancelled
}

enum PaymentMethod {
  cash
  card
  transfer
}

enum EntitlementStatus {
  gestor_push
  gestor_pull
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  name     String
  email    String
  password String
  role     String
  phone    String?
  bio      String?
  photo    String?

  userRoles     UserRole[]
  appointments  Appointment[]
  notifications Notification[]
}

model Role {
  id   Int    @id @default(autoincrement())
  name String

  userRoles UserRole[]
}

model UserRole {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Customer {
  id        Int    @id @default(autoincrement())
  name      String
  lastnames String
  phone     String
  email     String @unique

  appointments Appointment[]
}

model Service {
  id    Int    @id @default(autoincrement())
  name  String
  price Float

  appointmentsServices AppointmentsServices[]
}

model Product {
  id         Int       @id @default(autoincrement())
  name       String
  price      Float
  stock      Int       @default(0)
  categoryId Int?

  category             Category?              @relation(fields: [categoryId], references: [id])
  appointmentsProducts AppointmentsProducts[]
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String  @default("")

  products Product[]
}

model AppointmentsServices {
  appointmentId Int
  serviceId     Int

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  service     Service     @relation(fields: [serviceId], references: [id])

  @@id([appointmentId, serviceId])
}

model AppointmentsProducts {
  appointmentId Int
  productId     Int
  quantity      Int         @default(1)

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])

  @@id([appointmentId, productId])
}

model Appointment {
  id              Int               @id @default(autoincrement())
  title           String
  description     String
  customerId      Int
  userId          Int
  appointmentDate DateTime
  status          AppointmentStatus
  reminderSent    String
  stockDeducted   Boolean           @default(false)

  customer Customer               @relation(fields: [customerId], references: [id])
  user     User                   @relation(fields: [userId], references: [id])
  services AppointmentsServices[]
  products AppointmentsProducts[]
  payment  Payment?
}

model Payment {
  id            Int           @id @default(autoincrement())
  appointmentId Int           @unique
  amount        Float
  method        PaymentMethod
  paidAt        DateTime      @default(now())
  notes         String        @default("")

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Entitlement {
  id        Int               @id @default(autoincrement())
  payload   Json
  source    String
  status    EntitlementStatus
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}
